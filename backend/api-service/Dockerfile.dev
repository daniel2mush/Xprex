# backend/auth-service/Dockerfile.dev
# (or api-services/Dockerfile.dev)

FROM node:22-alpine

# Enable pnpm via corepack
RUN corepack enable

WORKDIR /app

# 1. Copy root workspace config first (for cache)
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml* ./

# 2. Copy workspace package.jsons so pnpm knows about @social/db
COPY database/package.json ./database/
COPY auth-service/package.json ./auth-service/

# 3. Copy the entire database folder (schema.prisma + postinstall hook)
#    This is what runs `prisma generate` during install
COPY database/ ./database/

# 4. Install everything (links workspace + runs postinstall = prisma generate)
RUN pnpm install

# 5. Hot-reload volumes (in docker-compose) will now overlay the source code
#    while keeping node_modules + generated/client intact

CMD ["pnpm", "--filter", "api-service", "run", "dev"]