{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node", // Ensures TS finds winston in node_modules
    "rootDir": "./src",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true // Helpful if you want to import your package.json for versioning
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"] // Added dist to avoid circular compilation issues
}