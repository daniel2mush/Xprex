{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",                 // ← changed
    "moduleResolution": "node",           // ← changed (ts-node friendly)
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist",
    "declaration": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}